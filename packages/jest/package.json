{
  "name": "@oxc-angular-testing/jest",
  "version": "0.0.0",
  "description": "Jest transformer wiring up @oxc-angular-testing/transform for Angular unit tests.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "default": "./dist/presets.js"
    },
    "./html-transformer": {
      "types": "./dist/html-transformer.d.ts",
      "default": "./dist/html-transformer.js"
    },
    "./html-transformer-cjs": {
      "types": "./dist/html-transformer-cjs.d.ts",
      "default": "./dist/html-transformer-cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattlewis92/oxc-angular-testing.git",
    "directory": "packages/jest"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@oxc-angular-testing/transform": "workspace:*"
  },
  "peerDependencies": {
    "jest": ">=29"
  },
  "devDependencies": {
    "@oxc-project/runtime": "^0.134.0",
    "cross-env": "^7.0.3",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-jasmine2": "^30.4.2",
    "typescript": "^5.6.0",
    "zone.js": "0.16.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json",
    "test": "pnpm run test:cjs && pnpm run test:esm && pnpm run test:zone",
    "test:cjs": "jest --selectProjects cjs",
    "test:esm": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --selectProjects esm",
    "test:zone": "jest --selectProjects zone"
  }
}
