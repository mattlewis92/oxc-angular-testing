{
  "name": "@oxc-angular-testing/vitest",
  "version": "0.0.0",
  "description": "Vitest plugin wiring up @oxc-angular-testing/transform for Angular unit tests.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattlewis92/oxc-angular-testing.git",
    "directory": "packages/vitest"
  },
  "homepage": "https://github.com/mattlewis92/oxc-angular-testing#readme",
  "bugs": {
    "url": "https://github.com/mattlewis92/oxc-angular-testing/issues"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@oxc-angular-testing/transform": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=8",
    "vitest": ">=4"
  },
  "devDependencies": {
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/platform-browser": "^21.2.17",
    "@oxc-project/runtime": "^0.134.0",
    "@vitest/browser-playwright": "^4.1.8",
    "playwright": "^1.60.0",
    "rxjs": "^7.8.2",
    "sass-embedded": "^1.100.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts"
  }
}
