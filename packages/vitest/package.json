{
  "name": "@oxc-angular-testing/vitest",
  "version": "0.0.0",
  "description": "Vitest plugin wiring up @oxc-angular-testing/transform for Angular unit tests.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattlewis92/oxc-angular-testing.git",
    "directory": "packages/vitest"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "@oxc-angular-testing/transform": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=8",
    "vitest": ">=4"
  },
  "devDependencies": {
    "@oxc-project/runtime": "^0.134.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json",
    "test": "vitest run"
  }
}
